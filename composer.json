{
    "name": "psc-acme/util-shipping",
    "description": "Package util-shipping for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\UtilShipping\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/console": "^7.0",
        "symfony/process": "^7.0",
        "psc-acme/plugin-cart": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "infection/infection": "^0.27",
        "vimeo/psalm": "^5.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}